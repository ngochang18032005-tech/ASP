<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-theme">
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <nav class="sidebar glass-panel">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fa-solid fa-crown text-gradient"></i>
                    <span>LuxManage</span>
                </div>
            </div>
            
            <ul class="nav-links">
                <li class="nav-label">Main Menu</li>
                <li>
                    <a asp-controller="Dashboard" asp-action="Bookings" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Bookings" ? "active" : "")" style="background: rgba(212, 175, 55, 0.1); border-left: 4px solid #d4af37; margin-bottom: 5px;">
                        <i class="fa-solid fa-calendar-check" style="color: #d4af37;"></i>
                        <span style="font-weight: bold; color: #d4af37;">QUẢN LÝ ĐẶT PHÒNG</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Dashboard" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Tổng Quan</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Hotel" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Hotel" ? "active" : "")">
                        <i class="fa-solid fa-bed"></i>
                        <span>Khách Sạn</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Restaurant" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Restaurant" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fa-solid fa-utensils"></i>
                        <span>Bán Hàng (POS)</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Restaurant" asp-action="Menu" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Restaurant" && ViewContext.RouteData.Values["Action"]?.ToString() == "Menu" ? "active" : "")">
                        <i class="fa-solid fa-list-check"></i>
                        <span>Thực Đơn</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Report" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Report" ? "active" : "")">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Báo Cáo</span>
                    </a>
                </li>
                <li class="nav-label">Management</li>
                <li>
                    <a asp-controller="Employee" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employee" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fa-solid fa-users"></i>
                        <span>Nhân Viên</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Employee" asp-action="Customers" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employee" && ViewContext.RouteData.Values["Action"]?.ToString() == "Customers" ? "active" : "")">
                        <i class="fa-solid fa-address-book"></i>
                        <span>Khách Hàng</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Dashboard" asp-action="Bookings" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Bookings" ? "active" : "")">
                        <i class="fa-solid fa-calendar-check"></i>
                        <span>Đặt Phòng</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Setting" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Setting" ? "active" : "")">
                        <i class="fa-solid fa-gear"></i>
                        <span>Cài Đặt</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-profile glass-card">
                <img src="https://i.pravatar.cc/150?img=11" alt="Admin" class="avatar" />
                <div class="info">
                    <h6>Ngọc Hằng</h6>
                    <small>Super Admin</small>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar glass-panel">
                <div class="search-bar">
                    <i class="fa-solid fa-search"></i>
                    <input type="text" placeholder="Tìm kiếm nhanh..." />
                </div>
                <div class="topbar-actions">
                    <div class="dropdown">
                        <button class="action-btn position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="notificationBtn">
                            <i class="fa-regular fa-bell"></i>
                            <span class="badge position-absolute top-0 start-100 translate-middle bg-danger rounded-circle" id="notificationBadge" style="display:none;">0</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end glass-panel border-0 shadow-lg p-2 mt-2" style="width: 300px;" id="notificationList">
                            <li class="p-2 text-center text-muted small">Không có thông báo mới</li>
                        </ul>
                    </div>
                    <a href="/" class="action-btn" title="Đi tới Trang chủ Website"><i class="fa-solid fa-globe"></i></a>
                </div>
            </header>

            <!-- Page Content -->
            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let lastBookingId = 0;
        let unreadCount = 0;

        async function initNotification() {
            try {
                const response = await fetch('/api/bookings/latest');
                const data = await response.json();
                if (data) lastBookingId = data.id;
                updateNotificationList();
            } catch (e) {}
            
            setInterval(checkNewBookings, 10000);
        }

        async function updateNotificationList() {
            try {
                const response = await fetch('/api/bookings/recent');
                const list = await response.json();
                const container = document.getElementById('notificationList');
                
                if (list && list.length > 0) {
                    container.innerHTML = '<li class="p-2 border-bottom fw-bold">Thông báo mới nhất</li>';
                    list.forEach(b => {
                        const time = new Date(b.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                        container.innerHTML += `
                            <li>
                                <a class="dropdown-item p-3 border-bottom d-flex align-items-center" href="/Dashboard/Bookings">
                                    <div class="me-3">
                                        <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="fa-solid fa-calendar-check text-dark"></i>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="fw-bold">#${b.id} - ${b.customerName}</div>
                                        <div class="small text-muted">Vừa đặt phòng lúc ${time}</div>
                                    </div>
                                </a>
                            </li>`;
                    });
                    container.innerHTML += '<li class="text-center p-2"><a href="/Dashboard/Bookings" class="small text-warning text-decoration-none">Xem tất cả</a></li>';
                }
            } catch (e) {}
        }

        async function checkNewBookings() {
            try {
                const response = await fetch('/api/bookings/latest');
                const data = await response.json();
                
                if (data && data.id > lastBookingId) {
                    lastBookingId = data.id;
                    unreadCount++;
                    
                    // Cập nhật Badge
                    const badge = document.getElementById('notificationBadge');
                    badge.innerText = unreadCount;
                    badge.style.display = 'block';

                    // Cập nhật danh sách
                    updateNotificationList();
                    
                    // Toast thông báo
                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 5000,
                        timerProgressBar: true
                    });

                    Toast.fire({
                        icon: 'info',
                        title: 'Có đơn đặt phòng mới!',
                        text: `Khách hàng: ${data.customerName} vừa đặt phòng.`
                    });
                }
            } catch (e) {}
        }

        // Xóa số thông báo khi bấm vào chuông
        document.getElementById('notificationBtn').addEventListener('click', () => {
            unreadCount = 0;
            document.getElementById('notificationBadge').style.display = 'none';
        });

        document.addEventListener('DOMContentLoaded', initNotification);
    </script>
</body>
</html>
